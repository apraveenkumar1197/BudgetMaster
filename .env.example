# Laravel app
APP_ENV=production
APP_KEY=                        # php artisan key:generate --show
APP_DEBUG=false
APP_URL=http://localhost:8080

# MySQL
DB_DATABASE=budgetmaster
DB_ROOT_PASSWORD=secret
DB_USERNAME=budgetmaster
DB_PASSWORD=secret

# Laravel Passport OAuth
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# React (baked in at build time — rebuild the image after changing)
REACT_APP_API_BASE_URL=http://localhost:8080/api/

# Host ports (change if these conflict with other local services)
API_PORT=8080
FRONTEND_PORT=3000
